[Unit]
Description=Pizza Ranch FunZone Demo Chatbot
After=network.target ollama.service

[Service]
Type=simple
User=clarence
WorkingDirectory=/home/clarence/pizza-ranch-demo
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8081
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
